#!/usr/bin/env php
<?php

/**
 * Build the Docit static site using Protocol UI.
 * Data source: docs. UI: protocol-js (100% Protocol).
 *
 * Invoked as vendor/bin/build-docs from the project root.
 * For dogfooding: DOCIT_PROJECT_ROOT=. or --self
 */

$packageDir = realpath(dirname(__DIR__));
$projectRoot = getenv('DOCIT_PROJECT_ROOT')
    ? realpath(getenv('DOCIT_PROJECT_ROOT'))
    : (in_array('--self', $argv ?? [], true)
        ? $packageDir
        : dirname(dirname($packageDir)));

$outputDir = trim(getenv('DOCIT_OUTPUT_DIR') ?: 'docs/dist');
if ($outputDir === '' || preg_match('#\.\.|^/#', $outputDir)) {
    fwrite(STDERR, "Error: DOCIT_OUTPUT_DIR must be a path relative to project root (e.g. docs, build, public/docs).\n");
    exit(1);
}
$outputPath = $projectRoot . DIRECTORY_SEPARATOR . $outputDir;

chdir($packageDir);

// 1. Sync docs to protocol-js
$syncCmd = 'node scripts/sync-docs-to-protocol.js';
passthru($syncCmd, $code);
if ($code !== 0) {
    fwrite(STDERR, "Error: sync-docs-to-protocol failed.\n");
    exit(1);
}

// 2. Build Protocol (Next.js)
chdir($packageDir . DIRECTORY_SEPARATOR . 'protocol-js');
$protocolDir = getcwd();

// Run command with streaming output and stdin closed (prevents npm from blocking on TTY)
function runStreaming(string $cmd): int {
    $proc = proc_open(
        $cmd,
        [0 => ['pipe', 'r'], 1 => ['pipe', 'w'], 2 => ['pipe', 'w']],
        $pipes,
        null,
        null
    );
    if (!is_resource($proc)) {
        return 1;
    }
    fclose($pipes[0]);
    stream_set_blocking($pipes[1], false);
    stream_set_blocking($pipes[2], false);
    $stdout = $pipes[1];
    $stderr = $pipes[2];
    $code = null;
    while ($code === null) {
        $r = [$stdout, $stderr];
        $w = $e = [];
        if (stream_select($r, $w, $e, 1) !== false) {
            foreach ($r as $s) {
                $chunk = stream_get_contents($s);
                if ($chunk !== '') {
                    echo $chunk;
                }
            }
        }
        $status = proc_get_status($proc);
        $code = $status['running'] ? null : $status['exitcode'];
    }
    fclose($stdout);
    fclose($stderr);
    proc_close($proc);
    return $code ?? 1;
}

$nodeModules = $protocolDir . DIRECTORY_SEPARATOR . 'node_modules';
$nextBin = $nodeModules . DIRECTORY_SEPARATOR . '.bin' . DIRECTORY_SEPARATOR . 'next';
$needsInstall = !is_dir($nodeModules) || !file_exists($nextBin);

if ($needsInstall) {
    echo $needsInstall && is_dir($nodeModules)
        ? "Repairing npm dependencies (missing binaries)...\n"
        : "Installing npm dependencies (first run may take 1-2 min)...\n";
    $code = runStreaming('npm install --no-fund --no-audit 2>&1');
    if ($code !== 0) {
        fwrite(STDERR, "Warning: npm install failed, continuing.\n");
    }
} else {
    echo "npm dependencies present, skipping install.\n";
}
// For GitHub Pages: DOCIT_OUTPUT_DIR (default docs) is deployment root. Use DOCIT_BASE_PATH for subpath.
$basePath = getenv('DOCIT_BASE_PATH') ?: (in_array('--self', $argv ?? [], true) ? '/laravel-docit' : '');
echo "Building Next.js (this may take 1-2 minutes)...\n";
$npmBuild = $basePath !== '' ? "BASE_PATH=" . escapeshellarg($basePath) . " npm run build" : 'npm run build';
passthru($npmBuild, $code);
if ($code !== 0) {
    fwrite(STDERR, "Error: Protocol build failed.\n");
    exit(1);
}

// 3. Copy Protocol output (out/) to DOCIT_OUTPUT_DIR
$outDir = $packageDir . DIRECTORY_SEPARATOR . 'protocol-js' . DIRECTORY_SEPARATOR . 'out';
if (!is_dir($outDir)) {
    fwrite(STDERR, "Error: protocol-js/out not found after build.\n");
    exit(1);
}

if (is_dir($outputPath)) {
    $resolvedDocsDir = realpath($outputPath);
    $expectedBase = realpath($projectRoot);
    if ($resolvedDocsDir === false || $expectedBase === false) {
        fwrite(STDERR, "Error: Could not resolve docs path.\n");
        exit(1);
    }
    if ($resolvedDocsDir === '' || $resolvedDocsDir === '/' || $resolvedDocsDir === $expectedBase) {
        fwrite(STDERR, "Error: Refusing to delete output path for safety.\n");
        exit(1);
    }
    if (!str_starts_with($resolvedDocsDir, $expectedBase . DIRECTORY_SEPARATOR)) {
        fwrite(STDERR, "Error: Output path is outside project root.\n");
        exit(1);
    }
    $files = new RecursiveIteratorIterator(
        new RecursiveDirectoryIterator($resolvedDocsDir, RecursiveDirectoryIterator::SKIP_DOTS),
        RecursiveIteratorIterator::CHILD_FIRST
    );
    foreach ($files as $file) {
        $file->isDir() ? rmdir($file->getRealPath()) : unlink($file->getRealPath());
    }
    rmdir($resolvedDocsDir);
}

$iterator = new RecursiveIteratorIterator(
    new RecursiveDirectoryIterator($outDir, RecursiveDirectoryIterator::SKIP_DOTS),
    RecursiveIteratorIterator::SELF_FIRST
);

foreach ($iterator as $item) {
    $target = $outputPath . DIRECTORY_SEPARATOR . $iterator->getSubPathname();
    if ($item->isDir()) {
        if (!is_dir($target)) {
            mkdir($target, 0755, true);
        }
    } else {
        $targetDir = dirname($target);
        if (!is_dir($targetDir)) {
            mkdir($targetDir, 0755, true);
        }
        copy($item->getRealPath(), $target);
    }
}

// 4. Add .nojekyll for GitHub Pages
$nojekyll = $outputPath . DIRECTORY_SEPARATOR . '.nojekyll';
touch($nojekyll);

echo "Docs built successfully to {$outputPath}\n";
