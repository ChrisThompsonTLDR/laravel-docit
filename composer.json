{
    "name": "christhompsontldr/laravel-docit",
    "description": "Static site generator for documentation using Markdown and Protocol UI.",
    "keywords": [
        "documentation",
        "static site generator",
        "markdown",
        "github pages"
    ],
    "homepage": "https://github.com/ChrisThompsonTLDR/laravel-docit",
    "type": "project",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/ChrisThompsonTLDR/laravel-docit/issues",
        "source": "https://github.com/ChrisThompsonTLDR/laravel-docit"
    },
    "authors": [
        {
            "name": "Emma De Silva",
            "email": "emma@desilva.se"
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "autoload": {},
    "scripts": {
        "docit": "php bin/build-docs --self"
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "bin": [
        "bin/build-docs"
    ]
}
